// ============================================================
// SISTEMA DE LIGA/LADDER - Temporadas y Rankings Competitivos
// ============================================================

model Season {
  id          String       @id @default(cuid())
  name        String       // "Liga Verano 2025"
  slug        String       @unique // "liga-verano-2025"
  description String?
  startDate   DateTime
  endDate     DateTime
  status      SeasonStatus @default(UPCOMING)
  gameTypes   String[]     // ["ca", "duel", "tdm", "ctf", "ffa"]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relaciones
  ratings     SeasonRating[]
  matches     Match[]
  tournaments Tournament[]

  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model SeasonRating {
  id        String   @id @default(cuid())
  seasonId  String
  playerId  String
  steamId   String
  gameType  String
  rating    Float    @default(900.0)  // ELO base para liga
  deviation Float    @default(350.0)
  wins      Int      @default(0)
  losses    Int      @default(0)
  draws     Int      @default(0)
  games     Int      @default(0)
  lastPlayed DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  season    Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonId, steamId, gameType])
  @@index([seasonId])
  @@index([playerId])
  @@index([steamId])
  @@index([gameType])
  @@index([rating])
}

// Status monitoring history for uptime tracking
model StatusHistory {
  id          String   @id @default(cuid())
  service     String   // "api" or "servers"
  status      String   // "operational", "degraded", "down"
  responseTime Int?    // Response time in ms
  details     String?  // Additional info like "3/3 servers online"
  date        DateTime @default(now()) // The day this status was recorded
  createdAt   DateTime @default(now())

  @@unique([service, date]) // One record per service per day
  @@index([service])
  @@index([date])
}

// ============================================================
// AUDIT LOG - Sistema completo de auditoría
// ============================================================

model AuditLog {
  id         String        @id @default(cuid())
  category   AuditCategory
  action     String        // "BAN_PLAYER", "STEAM_LOGIN", "MATCH_PROCESSED", etc.
  actorType  ActorType     @default(USER)
  actorId    String?       // steamId, "system", null para anónimo
  actorName  String?       // Nombre denormalizado
  actorIp    String?
  targetType String?       // "player", "clan", "tournament", "match", etc.
  targetId   String?
  targetName String?       // Nombre denormalizado
  details    Json?         // Contexto variable (razón, duración, before/after)
  status     AuditStatus   @default(SUCCESS)
  method     String?       // GET, POST, PATCH, DELETE
  path       String?       // Ruta API
  userAgent  String?
  duration   Int?          // Duración del request en ms
  createdAt  DateTime      @default(now())

  @@index([category])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([category, createdAt])
}

enum AuditCategory {
  AUTH
  ADMIN
  PLAYER
  CLAN
  TOURNAMENT
  MATCH
  RATING
  SERVER
  CONTENT
  SYSTEM
}

enum ActorType {
  USER
  SYSTEM
  ANONYMOUS
}

enum AuditStatus {
  SUCCESS
  FAILURE
  ERROR
}

// ============================================================
// SISTEMA COMUNITARIO - Comentarios, Foro y Encuestas
// ============================================================

enum ForumThreadStatus {
  OPEN
  CLOSED
}

enum PollStatus {
  ACTIVE
  CLOSED
}

model Comment {
  id        String   @id @default(cuid())
  newsId    String
  authorId  String
  steamId   String
  username  String
  avatar    String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author Player @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([newsId, createdAt])
  @@index([authorId])
}

model ForumCategory {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  threads     ForumThread[]

  @@index([order])
}

model ForumThread {
  id          String            @id @default(cuid())
  categoryId  String
  title       String
  content     String
  authorId    String
  steamId     String
  username    String
  avatar      String?
  status      ForumThreadStatus @default(OPEN)
  isPinned    Boolean           @default(false)
  replyCount  Int               @default(0)
  lastReplyAt DateTime?
  lastReplyBy String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   Player        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies  ForumReply[]

  @@index([categoryId, isPinned, lastReplyAt])
  @@index([categoryId, createdAt])
  @@index([authorId])
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  steamId   String
  username  String
  avatar    String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author Player      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorId])
}

model Poll {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      PollStatus @default(ACTIVE)
  createdBy   String
  totalVotes  Int        @default(0)
  createdAt   DateTime   @default(now())
  closedAt    DateTime?
  updatedAt   DateTime   @updatedAt

  options PollOption[]
  votes   PollVote[]

  @@index([status, createdAt])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  text      String
  voteCount Int        @default(0)
  order     Int        @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId, order])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  voterId   String
  steamId   String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter  Player     @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([pollId, voterId])
  @@index([pollId])
  @@index([voterId])
}

model QuitRecord {
  id            String   @id @default(cuid())
  steamId       String
  matchId       String?
  gameType      String
  penaltyApplied Boolean @default(false)
  penaltyAmount  Int     @default(0)
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([steamId, createdAt])
  @@index([steamId, expiresAt])
}

// Permisos de admin por servidor de Quake Live
// Global admins (roles: admin/mod/founder en Player) tienen permisos en TODOS los servidores
// ServerPermission almacena permisos adicionales por servidor específico
model ServerPermission {
  id        String   @id @default(cuid())
  steamId   String
  serverId  String   // Identificador del servidor: ca_1, ca_2, duel_1, prc, etc.
  grantedBy String?
  grantedAt DateTime @default(now())
  notes     String?

  player Player @relation(fields: [steamId], references: [steamId], onDelete: Cascade)

  @@unique([steamId, serverId])
  @@index([serverId])
  @@index([steamId])
}

// Snapshots horarios de jugadores online para gráfico de peak hours
model ServerSnapshot {
  id          String   @id @default(cuid())
  hour        Int      // 0-23 (hora Chile)
  dayOfWeek   Int      // 0=domingo, 6=sábado
  playerCount Int
  recordedAt  DateTime @default(now())

  @@index([hour])
  @@index([recordedAt])
}

