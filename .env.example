# Base de datos
DATABASE_URL="postgresql://usuario:password@localhost:5432/quakeclub?schema=public"

# URL pública del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL="http://localhost:3001"

# Secretos de sesión y admin
SESSION_SECRET="cadena_larga_aleatoria"
ADMIN_PASSWORD="password_del_panel_admin"
CRON_SECRET="token_para_endpoints_de_cron"

# Steam (OpenID + API)
STEAM_API_KEY="tu_api_key_de_steam"

# Discord (bot opcional)
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""

# Twitch (para embeds y live status)
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
TWITCH_CHANNEL_NAME=""

# YouTube (highlights opcionales)
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""

# Integración con QLDS / plugin minqlx
MINQLX_API_KEY=""

# Servidores QLDS propios (separados por coma)
TRUSTED_SERVER_IPS=""
OUR_SERVER_IPS=""

# Lookup de servidores propios para mostrar país en el browser
# Formato JSON: {"<ip>":{"country":"...","countryCode":"..","region":"..."}}
OUR_SERVERS_JSON=""

# IP por defecto que carga el panel admin de ZMQ (queda en el bundle del cliente)
NEXT_PUBLIC_QLDS_DEFAULT_IP=""

# Acceso SSH al QLDS para tareas administrativas (scan de cuentas vinculadas, etc.)
QLDS_SSH_HOST="usuario@host"
QLDS_SSH_KEY_PATH=".llaves/qlds-server.key"
QLDS_SCAN_SCRIPT_PATH="/ruta/al/scan_linked_accounts.py"

# URL interna para los cron de mantención (por defecto http://localhost:3000)
INTERNAL_BASE_URL=""
